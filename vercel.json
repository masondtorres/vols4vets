    { "source": "/veteran-job-help-east-tennessee", "destination": "/veteran-job-help-east-tennessee.html" },
    { "source": "/veteran-legal-aid-east-tennessee", "destination": "/veteran-legal-aid-east-tennessee.html" },
    { "source": "/women-veterans-east-tennessee", "destination": "/women-veterans-east-tennessee.html" },
    { "source": "/military-family-caregiver-help", "destination": "/military-family-caregiver-help.html" },
    { "source": "/removed-utility-content", "destination": "/removed-utility-content.html" }
  ],
  "redirects": [
    { "source": "/screen-flashlight", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/dvd-screensaver", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/glitch-screen", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/guides/how-to-clean-your-screen-safely", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/guides/how-to-use-a-white-screen-for-video-calls", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/guides/dead-pixel-vs-stuck-pixel", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/guides/best-screen-colors-for-focus", "destination": "/removed-utility-content", "permanent": false },
    { "source": "/guides/how-to-check-backlight-bleed", "destination": "/removed-utility-content", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/components/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/removed-utility-content",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
