    { "source": "/resources-education", "destination": "/resources-education.html" },
    { "source": "/resources-business-entrepreneurship", "destination": "/resources-business-entrepreneurship.html" },
    { "source": "/resources-disability-caregiver", "destination": "/resources-disability-caregiver.html" },
    { "source": "/resources-women-veterans", "destination": "/resources-women-veterans.html" },
    { "source": "/resources-retirees", "destination": "/resources-retirees.html" },
    { "source": "/resources-east-tennessee-discounts", "destination": "/resources-east-tennessee-discounts.html" },
    { "source": "/resources-veteran-owned-businesses", "destination": "/resources-veteran-owned-businesses.html" },
    { "source": "/search", "destination": "/search.html" },
    { "source": "/find-my-next-step", "destination": "/find-my-next-step.html" },
    { "source": "/verification-policy", "destination": "/verification-policy.html" },
