    { "source": "/sevierville-veteran-resources", "destination": "/sevierville-veteran-resources.html" },
    { "source": "/sevier-county-veteran-resources", "destination": "/sevier-county-veteran-resources.html" },
    { "source": "/knoxville-veteran-resources", "destination": "/knoxville-veteran-resources.html" },
    { "source": "/knox-county-veteran-resources", "destination": "/knox-county-veteran-resources.html" },
    { "source": "/mountain-home-va-guide", "destination": "/mountain-home-va-guide.html" },
